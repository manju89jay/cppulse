{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "bash scripts/auto-lint.sh \"$TOOL_INPUT_PATH\""
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash scripts/save-session-state.sh"
          }
        ]
      }
    ],
    "Notification": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "notify-send 'cppulse Claude Code' \"$NOTIFICATION_MESSAGE\" 2>/dev/null || true"
          }
        ]
      }
    ]
  },
  "permissions": {
    "allow": [
      "Bash(cmake:*)",
      "Bash(make:*)",
      "Bash(ctest:*)",
      "Bash(ninja:*)",
      "Bash(clang-format:*)",
      "Bash(clang-tidy:*)",
      "Bash(pytest:*)",
      "Bash(python3:*)",
      "Bash(ruff:*)",
      "Bash(black:*)",
      "Bash(mypy:*)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git status:*)",
      "Bash(docker-compose:*)",
      "Bash(docker:*)",
      "Bash(npm:*)",
      "Bash(bash scripts/*:*)"
    ]
  }
}
